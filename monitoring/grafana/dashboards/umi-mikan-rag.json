{
  "id": null,
  "title": "umi.mikan RAG Monitoring",
  "tags": ["umi-mikan", "rag", "semantic-search", "embedding"],
  "style": "dark",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Semantic Search Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(backend_semantic_search_requests_total[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Semantic Search Duration (p95 / p50)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(backend_semantic_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 - {{status}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(backend_semantic_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 - {{status}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Total Semantic Searches (Last Hour)",
      "type": "stat",
      "targets": [
        {
          "expr": "increase(backend_semantic_search_requests_total[1h])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "title": "Average Search Results Count",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(backend_semantic_search_results_count_sum[5m]) / rate(backend_semantic_search_results_count_count[5m])",
          "legendFormat": "avg results",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "Search Success Rate (%)",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * rate(backend_semantic_search_requests_total{status=\"success\"}[5m]) / rate(backend_semantic_search_requests_total[5m])",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 8
      }
    },
    {
      "id": 6,
      "title": "Embedding Generation Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(subscriber_summaries_generated_total{summary_type=\"diary_embedding\"}[5m])",
          "legendFormat": "embeddings/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },
    {
      "id": 7,
      "title": "Embedding Processing Duration (p95 / p50)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(subscriber_processing_duration_seconds_bucket{message_type=\"diary_embedding\"}[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(subscriber_processing_duration_seconds_bucket{message_type=\"diary_embedding\"}[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      }
    },
    {
      "id": 8,
      "title": "Total Embeddings Generated (Last Hour)",
      "type": "stat",
      "targets": [
        {
          "expr": "increase(subscriber_summaries_generated_total{summary_type=\"diary_embedding\"}[1h])",
          "legendFormat": "embeddings",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 20
      }
    },
    {
      "id": 9,
      "title": "Embedding Message Success Rate (%)",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * rate(subscriber_messages_processed_total{message_type=\"diary_embedding\",status=\"success\"}[5m]) / rate(subscriber_messages_processed_total{message_type=\"diary_embedding\"}[5m])",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 20
      }
    },
    {
      "id": 10,
      "title": "Embedding Messages Queued vs Processed",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(scheduler_queued_messages_total{message_type=\"diary_embedding\"}[5m])",
          "legendFormat": "queued",
          "refId": "A"
        },
        {
          "expr": "rate(subscriber_messages_processed_total{message_type=\"diary_embedding\"}[5m])",
          "legendFormat": "processed - {{status}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "5s",
  "schemaVersion": 27,
  "version": 0
}
